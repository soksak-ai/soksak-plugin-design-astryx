{
  "name": "soksak-plugin-design-astryx",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "gen": "node scripts/gen-catalog.mjs && node scripts/gen-templates.mjs && node scripts/gen-docs.mjs",
    "build:css": "node scripts/build-css.mjs",
