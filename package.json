    "@astryxdesign/theme-matcha": "0.1.3",
    "@astryxdesign/theme-neutral": "0.1.3",
    "@astryxdesign/theme-stone": "0.1.3",
    "@astryxdesign/theme-y2k": "0.1.3",
    "@heroicons/react": "^2.2.0",
    "@stylexjs/stylex": "0.18.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
